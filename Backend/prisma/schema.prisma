datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
}

model Student {
  id              String   @id @default(uuid())
  admissionNumber String   @unique
  name            String
  classStreamId   String
}
