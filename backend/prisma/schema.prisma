datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
}

model Student {
  id              String   @id @default(uuid())
  admissionNumber String   @unique
  name            String
  classStreamId   String
  scores          Score[]
}

model Score {
  id        String   @id @default(uuid())
  studentId String
  subjectId String
  ca1       Float?
  ca2       Float?
  exam      Float?
  total     Float?
  grade     String?
  student   Student  @relation(fields: [studentId], references: [id])
}
